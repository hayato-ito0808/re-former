<%= form_with model: @user do |f| %>
  <%= f.label :username, "名前：" %>
  <%= f.text_field :username %>

  <%= f.label :email, "メールアドレス：" %>
  <%= f.text_field :email %>

  <%= f.label :password, "パスワード：" %>
  <%= f.password_field :password %>

  <%= f.submit "送信" %>
<% end %>